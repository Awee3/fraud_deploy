        "jsCode": "// Ambil semua commit\nconst commits = items[0].json.body.commits;\n\n// Gabungkan semua file yang di-modified/added\nlet allFiles = [];\nfor (const commit of commits) {\n  allFiles = allFiles.concat(commit.modified, commit.added);\n}\n\n// Cari file yang akhiran .pkl\nconst modelFile = allFiles.find(file => file.endsWith('.pkl'));\n\n// Return path file tersebut\nreturn [{\n  json: {\n    model_path: modelFile \n  }\n}];"
      },
