    {
      "parameters": {
        "jsCode": "// 1. Ambil data transaksi dari API\nconst httpItems = $items(\"HTTP Request\");\nlet logs = [];\n\n// HTTP Request n8n kadang memecah array JSON menjadi beberapa item terpisah.\n// Kita gabungkan kembali menjadi satu array utuh untuk dihitung.\nfor (let item of httpItems) {\n  if (Array.isArray(item.json)) {\n    logs = logs.concat(item.json);\n  } else {\n    logs.push(item.json);\n  }\n}\n\n// 2. BACA FILE BASELINE DENGAN NATIVE API N8N (Paling Aman)\nlet baselineData;\ntry {\n  // getBinaryDataBuffer secara otomatis menangani segala jenis kompresi/encoding bawaan n8n\n  const binaryBuffer = await this.helpers.getBinaryDataBuffer(0, 'data');\n  const jsonString = binaryBuffer.toString('utf8');\n  \n  baselineData = JSON.parse(jsonString);\n} catch (error) {\n  // Jika masih gagal, ini akan menampilkan apa sebenarnya isi file tersebut\n  return [{ \n    json: { \n      error: \"Gagal membaca isi file JSON. Pastikan file static_baseline.json benar-benar teks murni.\", \n      pesan_sistem: error.message \n    } \n  }];\n}\n\n// 3. Validasi Data\nif (logs.length === 0 || Object.keys(logs[0]).length === 0) {\n  return [{ json: { error: \"Log transaksi kosong dari API.\" } }];\n}\n\nconst featureToCheck = \"V14\";\n\nif (!baselineData || !baselineData[featureToCheck]) {\n  return [{ json: { error: `Fitur '${featureToCheck}' tidak ditemukan di file baseline.` } }];\n}\n\n// 4. Kalkulasi Data Drift\nconst baselineMean = baselineData[featureToCheck].mean;\n\nlet sum = 0;\nlogs.forEach(row => {\n  sum += (row[featureToCheck] || 0); \n});\nconst productionMean = sum / logs.length;\n\nconst difference = Math.abs(productionMean - baselineMean);\nconst threshold = 0.1; \n\nconst isDrifting = difference > threshold;\n\n// 5. Keluarkan Hasil\nreturn [{\n  json: {\n    feature: featureToCheck,\n    baseline_mean: baselineMean,\n    production_mean: productionMean,\n    difference: difference,\n    threshold: threshold,\n    is_drifting: isDrifting,\n    total_analyzed: logs.length\n  }\n}];"
      },
